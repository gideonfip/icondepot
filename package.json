{
	"name": "dashboard-icons",
	"version": "0.1.0",
	"private": true,
	"description": "Fork of homarr-labs/dashboard-icons with custom additions and lobe-icons sync",
	"scripts": {
		"dev": "cd web && pnpm dev",
		"dev:web": "cd web && pnpm run dev:web",
		"backend:start": "cd web && pnpm run backend:start",
		"build": "cd web && pnpm build",
		"sync:lobe": "node scripts/sync-lobe-icons.mjs --apply",
		"sync:lobe:dry": "node scripts/sync-lobe-icons.mjs",
		"normalize": "node scripts/normalize.mjs --apply",
		"normalize:dry": "node scripts/normalize.mjs",
		"sync:all": "npm run sync:lobe && npm run normalize",
		"lint": "cd web && pnpm lint",
		"typecheck": "cd web && pnpm typecheck"
	},
	"devDependencies": {
		"@types/bun": "^1.3.5",
		"@types/node": "^25.0.3"
	}
}
